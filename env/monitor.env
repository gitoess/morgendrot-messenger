# =============================================================================
# Morgendrot Monitor-Instanz (zweite Datei, parallel zum Messenger)
# Nutzung:
#   1) Backup:  Copy-Item .env ".env.backup-$(Get-Date -Format yyyyMMdd-HHmmss)"
#   2) Aktivieren: Copy-Item "env/monitor.env" .env
#   3) Starten: npm run dev
#
# Hinweis:
# - Für "Messenger + Monitor in EINER Instanz" reicht in der normalen .env:
#     ROLE=messenger (oder boss) + ENABLE_MONITOR=true
# - Diese Datei ist für eine SEPARATE Monitor-Instanz gedacht (andere Ports).
# =============================================================================

# ========== NETZWERK ==========
RPC_URL=https://api.testnet.iota.cafe

# ========== PACKAGE / SHARED ==========
PACKAGE_ID=0xcf409a0387de039a707d1916afeb16f17a22969a0735e8cfeeaaf5b5fa3d811f
MAILBOX_ID=0xcf231121f32227f8c55d30454c0ca90955d33b220a26a988d496085bace7fcaf
EVENT_REGISTRY_ID=0x0690ce3d2c49711d81113f07279fff73cd18717af730fd708e485cadb2e752b2

# ========== ROLLE / PROFIL ==========
# Dedizierter Monitor:
ROLE=monitor
DEPLOYMENT_PROFILE=einsatz
UI_VARIANT=full
SIMPLE_MODE=false

# ========== MONITOR ==========
ENABLE_MONITOR=true
MONITOR_DEVICES=0x671bf669a858c97a1ca7ed3c5c31901ffb671ceea31e8fd706d0b6e2cb8a15c5
MONITOR_OFFLINE_TIMEOUT_MS=1800000
MONITOR_CHECK_INTERVAL_MS=300000
MONITOR_STATE_FILE=.morgendrot-monitor-state.json
MONITOR_ALARM_WEBHOOK_URL=http://127.0.0.1:8787/morgendrot-telegram

# ========== HEARTBEAT ==========
ENABLE_HEARTBEAT=true
HEARTBEAT_INTERVAL_MS=60000

# ========== TELEGRAM RELAY ==========
# Legacy-Token nur falls noch nicht auf Runtime-Integration umgestellt:
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_WEBHOOK_PORT=8787

# ========== UI / API (andere Ports für Parallelbetrieb) ==========
ENABLE_UI=true
UI_PORT=3344
API_PORT=3345
API_KILL_PREVIOUS_INSTANCE=false

# ========== LOG ==========
LOG_VERBOSE=false
ENABLE_FILE_LOGGING=true
LOG_MAX_FILES=7
LOG_MAX_SIZE=20m
