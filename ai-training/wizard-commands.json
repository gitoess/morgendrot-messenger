        },
        {
          "cmd": "/emergency-purge",
          "params": [],
          "param_types": [],
          "description": "Vault Notfall-Purge (enable + purge). VAULT_REGISTRY_ID nötig."
        },
        {
          "cmd": "/purge-key",
          "params": ["key_id"],
          "param_types": ["0x64hex"],
          "description": "AccessKey löschen (Storage-Rebate). Zuerst /list-keys. ENABLE_PURGE."
        },
        {
          "cmd": "/purge-keys",
          "params": ["key_id_1", "key_id_2", "..."],
          "param_types": ["0x64hex_list"],
          "description": "Mehrere Keys in einer TX purgen (Bulk)."
        }
      ]
    }
