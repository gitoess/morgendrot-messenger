# Optional: Factory I/O → Streams-Demo (nicht Teil des Messenger-Standard-Setups).
# Kopieren nach .env oder per Hand mergen. Messenger-Lite-UI: ENABLE_FACTORY_IO=true,
# Backend neu starten – dann erscheint der Abschnitt „Factory I/O Feeder“ unter Streams.
# Siehe docs/FACTORY-IO-INTEGRATION.md

ENABLE_FACTORY_IO=true
FACTORY_IO_URL=http://127.0.0.1:7410
FACTORY_IO_POLL_MS=10000
# FACTORY_IO_MAP_FILE=./factory-io-map.json
# FACTORY_IO_PUBLISH_ON_CHANGE=1
# MORGENDROT_API_URL=http://127.0.0.1:3342
