# =============================================================================
# Morgendrot – .env – Übersichtliche & intuitive Konfiguration
# Stand: März 2026
# Doku: docs/CONFIG-REFERENCE.md
# =============================================================================
# Kopie als .env verwenden. Leer = Default oder aus.
# Bei verschlüsselter Env: ENCRYPTED_ENV_FILE setzen → "npm run start:secrets"
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. NETZWERK & CHAIN (wo die Kette läuft)
# ──────────────────────────────────────────────────────────────────────────────
RPC_URL=
# Default: https://api.testnet.iota.cafe (Fullnode-URL liefert für Transaktionen/getCoins oft HTTP 404)
# Zusätzliche öffentliche Nodes (Komma/Leerzeichen); Rotation: POST /api/rpc-rotate oder Befehl /rpc-rotate
RPC_URLS=
# HTTP(S)-Proxy für alle RPC-Requests (Node fetch); z. B. http://127.0.0.1:8118 (Privoxy vor Tor). Kein SOCKS in allen Setups – ggf. lokalen HTTP-Proxy nutzen.
RPC_HTTP_PROXY=
# 1–3: Vertrauensstufe nur als Hinweis (1=öffentliche RPCs, 2=Proxy empfohlen, 3=eigener Node)
NETWORK_TRUST_TIER=1

# PWA (Next): optionaler **direkter** IOTA-Fullnode für Light-Client — kein Morgendrot-`/api`-Pflicht (siehe docs/ARCHITECTURE-HANDY-FIRST-CLIENT-IOTA.md).
# Überschreibbar im Browser per localStorage `morgendrot.directIotaRpcUrl`.
NEXT_PUBLIC_DIRECT_IOTA_RPC_URL=

# ──────────────────────────────────────────────────────────────────────────────
# 2. PROGRAMM & SHARED-OBJEKTE (einmalig nach create_globals setzen)
# ──────────────────────────────────────────────────────────────────────────────
COMMAND_REGISTRY_ID=
MAILBOX_ID=
# Frühere Shared-Mailbox-IDs (eine 0x…64 pro Zeile) — Inbox-Union, siehe .morgendrot-mailbox-id-history
# MAILBOX_ID_HISTORY_FILE=.morgendrot-mailbox-id-history
# Optional: Prepaid Messenger-Credits (owned Move-Objekt, nicht dasselbe wie MIST-Guthaben).
# Credits = euer Tarif/Kontingent; MIST = natives Gas auf der Chain (siehe docs/MESSENGER-OPERATIONAL-LIMITS-AND-GAS-POLICY.md §8).
# Nur mit USE_MAILBOX + Package mit store_*_with_credits.
# MESSENGER_CREDITS_OBJECT_ID=
PACKAGE_ID=
PACKAGE_ID_FILE=.morgendrot-package-id
VAULT_REGISTRY_ID=

# § H.33 — Einsatz-Manifest-Anker (nur Boss, nicht im Helfer-ZIP). Deploy: docs/DEPLOY-MOVE-H33-EINSATZ-MANIFEST.md
# EINSATZ_MANIFEST_REGISTRY_ID=
# MAINNET_RPC_URL=https://api.mainnet.iota.cafe
# MAINNET_PACKAGE_ID=

# ──────────────────────────────────────────────────────────────────────────────
# 3. WALLET & IDENTITÄT (wer bin ich?)
# ──────────────────────────────────────────────────────────────────────────────
MY_ADDRESS=
ROLE=messenger
# messenger | lock | monitor | boss | kommandant | arbeiter
# DEPLOYMENT_PROFILE=consumer
# consumer = Privat/Prepper | einsatz = Organisation — sonst aus ROLE/UI_VARIANT abgeleitet
# TRANSPORT_PROFILE=mesh-first
# mesh-first = Funk-Default in UI (IOTA-Backend bleibt) | iota-anchored | iota-full — docs/TRANSPORT-AND-IOTA-LAYERS.md
# SIMPLE_MODE=true
# true = schlanke UI für Helfer/Wanderer (§ H.0-SIMPLE); Boss/Kommandant: false

# ──────────────────────────────────────────────────────────────────────────────
# 4. PARTNER & GRUPPEN (mit wem spreche ich?)
# ──────────────────────────────────────────────────────────────────────────────
AUTHORIZED_SENDERS=
BOSS_ADDRESS=
BROADCAST_AUTHORIZED_SENDERS=
BROADCAST_PINNWAND_ADDRESS=
ENABLE_BROADCAST_PINNWAND=false
ENABLE_PAIRWISE_GROUPS=false
KOMMANDANT_ADDRESSES=
PARTNER_ADDRESS=
PARTNER_ADDRESS_FILE=.morgendrot-partner
PARTNER_ADDRESSES=
WORKER_ADDRESSES=
# JSON: {"0x…64":"arbeiter"|"kommandant"|…} — Boss setzt per /set-role <addr> <rolle> oder UI (optional)
DEVICE_ROLES={}

# ──────────────────────────────────────────────────────────────────────────────
# 5. SICHERHEIT & VERSCHLÜSSELUNG
# ──────────────────────────────────────────────────────────────────────────────
ENABLE_PLAINTEXT_CHANNEL=false
# true = Klartext erlauben (nur Test/Demo)
ENABLE_PURGE=true
ENABLE_REPLAY_PROTECTION=true
REPLAY_STATE_FILE=
USE_ENCRYPTED_DISCOVERY=false

# Messenger: Klartext-/Ciphertext-Budget pro Nachricht (UTF-8 bzw. vector<u8>).
# Default im Code: 16000 UTF-8 / 16384 vector<u8> (stabiler Stand; kein Anheben über diese Werte per Env möglich).
# Optional nur zum **Senken** (z. B. 4096): MESSENGER_MAX_PLAINTEXT_UTF8_BYTES=4096
# Sneakernet .morg-pkg (USB/Air-Gap, nicht On-Chain): Default 524288 (512 KiB), max. 4194304
# MORG_PKG_MAX_PLAINTEXT_UTF8_BYTES=524288

# ffmpeg: Standard zuerst gebündelt unter tools/ffmpeg/bin/ (siehe tools/ffmpeg/README.md).
# Nur nötig, wenn kein lokales Binary und kein PATH:
#   MORG_FFMPEG_PATH=C:\Pfad\ffmpeg.exe
#   FFMPEG_PATH=… (gleiche Wirkung)
# MORG_OPUS_BITRATE=8k
# MORG_OPUS_USE_SILENCE_REMOVE=1

# SIGNER=cli: große TX — `--data -` / `--tx-bytes -` + volle Base64 auf stdin (ein Write; kein CLI-@file).
# MORG_DEBUG_IOTA_CLI=1

# ──────────────────────────────────────────────────────────────────────────────
# 6. FEATURES & MODI (was soll aktiviert sein?)
# ──────────────────────────────────────────────────────────────────────────────
ENABLE_AUTO_EXECUTE=true
ENABLE_FETCH_COMMAND=true
ENABLE_FILE_LOGGING=true
ENABLE_HARDWARE_OPEN=true
ENABLE_LISTENER=true
FETCH_LAST_ON_START=0
LOG_VERBOSE=false
MAX_SEND_AMOUNT_IOTA=
USE_MAILBOX=true
# Klartext persistent in der Shared-Mailbox (purgebar; Move: store_plaintext_message_stored).
# Getrennt von der UI-Option „Persistent (Mailbox)“ — diese Server-Flags müssen passen.
# Fehlt die Zeile in .env → Default false. Boss: Runtime unter „.env anpassen“ oder Transport-Card.
MAILBOX_STORE_PLAINTEXT=false
# Phase 2: HD-Kontakt-Adressen (Stub – Ableitung folgt; true schaltet nur das Flag)
ENABLE_HD_CONTACT_ADDRESSES=false

# ──────────────────────────────────────────────────────────────────────────────
# 7. ZEIT & INTERVALLE (ms bzw. Tage)
# ──────────────────────────────────────────────────────────────────────────────
ANCHOR_INTERVAL_MS=86400000
DEFAULT_KEY_TTL_DAYS=30
DEFAULT_TTL_DAYS=30
HANDSHAKE_REFRESH_MS=5000
HEARTBEAT_INTERVAL_MS=600000
LISTENER_POLL_MS=5000
LOCK_COMMAND_POLL_MS=3000
LOCK_PEER_REFRESH_MS=15000
MONITOR_CHECK_INTERVAL_MS=300000
MONITOR_OFFLINE_TIMEOUT_MS=1800000
PAYMENT_TRIGGER_POLL_MS=15000

# Geheimnis-Peering: /pairing-find lädt höchstens PAIRING_FIND_MAX_CANDIDATES Events, pro Lauf höchstens PAIRING_FIND_MAX_DECRYPT_ATTEMPTS Trial-Decrypts auf noch gültige Offers.
PAIRING_FIND_MAX_CANDIDATES=250
PAIRING_FIND_MAX_DECRYPT_ATTEMPTS=80
# Optional „Lite“-Preset für die UI (Setup → „Standard-Briefkasten anwenden“): 0x+64 Hex; RPC leer = aktuelles RPC_URL
MORGENDROT_LITE_PACKAGE_ID=
MORGENDROT_LITE_RPC_URL=

# ──────────────────────────────────────────────────────────────────────────────
# 8. HARDWARE & AUSFÜHRUNG (Lock: physische Aktionen bei OPEN)
# ──────────────────────────────────────────────────────────────────────────────
LOCK_ID=
OPEN_COMMAND=
OPEN_COMMAND_LIST_FILE=
OPEN_COMMAND_LIST_KEY=
OPEN_COMMAND_WORDS=open,öffnen
OPEN_URL=

# ──────────────────────────────────────────────────────────────────────────────
# 9. STREAMS (letzte Meile: feeless, <1s, Metadaten-Schutz. Rebased bleibt für
#    Handshake, AccessKey, Purge. Streams für „open“, Status, Heartbeat.)
#    Ablauf & Fallback: docs/STREAMS-INTEGRATION.md §3a–3b
# ──────────────────────────────────────────────────────────────────────────────
OPEN_STREAMS_ENABLED=false
STREAMS_ANCHOR_ID=
STREAMS_BRIDGE_URL=
STREAMS_LISTEN_ENABLED=false
STREAMS_TOPIC=

# ──────────────────────────────────────────────────────────────────────────────
# 10. DATEIEN, SIGNER & UI
# ──────────────────────────────────────────────────────────────────────────────
# Dateien
GAS_BUDGET=10000000
# Sponsored TX + Messenger: erste sinnvolle Chain-TX selbst (z. B. nach Shadow-Sweep), ab der zweiten bei MESSENGER_AUTO_SPONSOR + Lizenz-NFT → SPONSOR_GAS_OWNER zahlt (SPONSOR_GAS_PASSWORD nötig).
# SPONSORED_TRANSACTION_ENABLED=false
# SPONSOR_GAS_OWNER=
# SPONSOR_GAS_PASSWORD=
# MESSENGER_AUTO_SPONSOR=false
# Self-Pay (Zielbild, wenn implementiert): bei Credits=0 mit eigenem MIST senden. Default aus = kein stiller MIST-Verbrauch.
# ENABLE_MESSENGER_SELF_PAY=false
# MESSENGER_LICENSE_NFT_OBJECT_ID=
# Optional: Geheimnis-Peering nur mit Besitz dieses NFT (Türsteher)
# PAIRING_GATE_NFT_OBJECT_ID=
# IOTA Names (Indexer iotax_iotaNamesLookup): GET /api/iota-name-lookup?name=… ; Messenger /resolve-iota-name
# Kommagetrennte Package-IDs (0x+64 Hex): Registrierungs-NFT muss von einem dieser Pakete stammen (sonst Warnung).
# VERIFIED_IOTA_NAME_PACKAGE_IDS=
# Optional: Pfad zur Datei für selbstbezahlte Messenger-TX (Gas-Meilenstein). Leer = .messenger-gas-state.json im cwd
# MESSENGER_GAS_STATE_FILE=
# Gas Station (Remote-Sponsor, Anbindung vorbereitet)
# IOTA_GAS_STATION_URL=
# Shadow-Sweep: MIST-Reserve auf Schatten-Adresse (Default 55000000)
# SHADOW_SWEEP_GAS_RESERVE_MIST=55000000
LOG_MAX_FILES=7
LOG_MAX_SIZE=20m
# VAULT_FILE: optional. Leer lassen = trotzdem .morgendrot-vault im Arbeitsverzeichnis (interner Default überall: CFG.VAULT_FILE || '.morgendrot-vault').
# Nur setzen, wenn du einen anderen Pfad willst, z. B. VAULT_FILE=.morgendrot-vault-büro
# Hinweis: Wenn hier ein nicht-leerer Wert steht, gilt „Vault-Modus“ für /connect (Rückfrage Keys speichern) auch ohne bestehende Datei.
VAULT_FILE=

# Signer: cli | remote | sdk
REMOTE_SIGNER_TOKEN=
REMOTE_SIGNER_URL=
# Vom Raspi/Gerät erreichbare URL des Boss-Signers (Provisioning: automatisch in Geräte-.env)
# Beispiel: http://192.168.1.50:3340/sign
BOSS_SIGNER_PUBLIC_URL=
# Boss legt Geräte-Adressen an (Keys zuweisen, MY_ADDRESS je Gerät in der .env) — jede Maschine bleibt eigene Identität; nicht die Boss-Adresse wiederverwenden.
# PWA / Android / Offline-UI (Entsperr-Dialog mit Mnemonic im Browser): SIGNER=sdk — sonst kein Seed-Feld (cli = IOTA-CLI am Rechner).
# Standard für lokale Entwicklung mit IOTA-CLI:
SIGNER=cli
WALLET_DERIVATION_PATH=

# Zahlungs-Trigger (Lock)
PAYMENT_TRIGGER_ENABLED=false
PAYMENT_TRIGGER_MIN_IOTA=
PAYMENT_TRIGGER_REQUIRE_MEMO=
PAYMENT_TRIGGER_STATE_FILE=

# Offline-Fähigkeit (Lock)
OFFLINE_CACHE_TTL_MS=86400000
OFFLINE_OPEN_ENABLED=false
OFFLINE_QUEUE_FILE=

# Heartbeat & Monitor (ROLE=monitor)
AUDIT_LOG_FILE=
ENABLE_CHAIN_ANCHOR=false
ENABLE_HEARTBEAT=false
MONITOR_ALARM_WEBHOOK_URL=
MONITOR_DEVICES=
MONITOR_ESCALATION_DELAY_MS=300000
MONITOR_ESCALATION_WEBHOOK_2=
MONITOR_ESCALATION_WEBHOOK_3=
MONITOR_PURGE_AFTER_DAYS=0
MONITOR_SENSOR_MAX_TEMP=
MONITOR_SENSOR_MIN_TEMP=
MONITOR_SENSOR_STATE_FILE=
MONITOR_STATE_FILE=

# UI (Offline-Referenz + API)
API_PORT=3342
# Bind 0.0.0.0 = Handy im WLAN erreicht Boss-API (Standard). Nur localhost: 127.0.0.1
API_BIND_HOST=0.0.0.0
# Optional: LAN-Token für Vault-Secret-Befehle vom Helfer-Handy (Header Bearer oder X-Morgendrot-Api-Token)
# API_AUTH_TOKEN=
# true = CORS nur gleicher Host/Loopback (evil.html auf anderer LAN-IP blockiert)
# API_STRICT_CORS=false
ENABLE_UI=false
# Öffentlicher Claim-Token-Endpunkt (Shop-E-Mail-Link); Idempotenz-Schicht — siehe docs/API-VOUCHER-CLAIM-SPEC.md
ENABLE_VOUCHER_CLAIM_API=false
# 0 = Rate-Limit aus; sonst max. POST /api/voucher-claim pro IP und Minute
VOUCHER_CLAIM_RATE_LIMIT_PER_MINUTE=30
# Integrierter Shop (Stripe) — docs/API-SHOP-SPEC.md
ENABLE_SHOP_API=false
# Basis für Stripe Redirects; leer = http://127.0.0.1:UI_PORT
# SHOP_PUBLIC_BASE_URL=http://127.0.0.1:3341
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Price-ID aus Stripe Dashboard (Beispielprodukt)
# SHOP_STRIPE_PRICE_MESSAGES_500=price_...
# SHOP_CHECKOUT_RATE_LIMIT_PER_MINUTE=20
# Nach Stripe-Zahlung: mint_messenger_credits_batch an recipient_iota_address (Checkout-Feld)
# ENABLE_SHOP_CHAIN_MINT=false
# SHOP_MINT_BOSS_WALLET_PASSWORD=
# Optional: HTTPS-POST an eigenes Mail-Backend (Claim-Token per Mail)
# SHOP_CLAIM_NOTIFY_WEBHOOK_URL=
# SHOP_CLAIM_NOTIFY_SECRET=
UI_PORT=3341
# Next.js (frontend/next.config.mjs lädt diese Root-.env) — keine zweite Datei unter frontend/
# Handy im WLAN: optional zusätzliche Origins (LAN-IPs werden in next.config oft automatisch ergänzt)
# NEXT_ALLOWED_DEV_ORIGINS=http://192.168.178.41:3341
# (next.config normalisiert zu host:port; Dev nach Änderung neu starten)
# Nur wenn API nicht auf 3342: MORGENDROT_API_INTERNAL_URL=http://127.0.0.1:3343
# true = Lite-UI (ui/) am API-Port. false = nur /api/* dort; Oberfläche nur Next (UI_PORT) – weniger Doppel-UI im Dev.
# SERVE_LITE_UI_STATIC=true
ENABLE_AI_INTENT_MATCHER=false
ENABLE_AI_COPILOT=false
# Größeres Modell = bessere Logik (z. B. qwen2:1.5b, qwen2:3b). Default: qwen2:0.5b (sparsam).
OLLAMA_MODEL=qwen2:0.5b
# RAG: Top-K Chunks (Default 5, Token-Hygiene). Optional: RAG_TOP_K=7
