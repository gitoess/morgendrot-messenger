# LoRa-Bridge – Konfiguration
# Morgendrot setzt STREAMS_BRIDGE_URL=http://localhost:9342

# HTTP-Port der Bridge
LORA_BRIDGE_PORT=9342

# Simulation (keine Hardware). true = Tests ohne Heltec
LORA_BRIDGE_SIMULATION=true

# Serial-Port für LoRa (nur wenn SIMULATION=false)
# LORA_SERIAL_PORT=COM3
# LORA_SERIAL_PORT=/dev/ttyUSB0

# Baudrate
# LORA_BAUD_RATE=115200

# Max. Payload (Bytes). LoRa typisch 250
# LORA_MAX_PAYLOAD_BYTES=240

# Optional: API-Key für Auth
# LORA_BRIDGE_API_KEY=

# CORS (kommagetrennt). Leer = alle
# LORA_BRIDGE_CORS_ORIGINS=
