# =============================================================================
# Morgendrot – .env für Messenger + Monitor in einer Instanz
# ROLE=messenger bleibt; ENABLE_MONITOR=true startet den Monitor im Hintergrund.
# Doku: docs/CONFIG-REFERENCE.md, docs/ENV-ERKLAERUNG.md
# =============================================================================

# ========== NETZWERK ==========
RPC_URL=https://api.testnet.iota.cafe

# ========== PACKAGE & SHARED OBJECTS ==========
PACKAGE_ID=create_globals
PACKAGE_ID_FILE=.morgendrot-package-id
VAULT_REGISTRY_ID=
MAILBOX_ID=
COMMAND_REGISTRY_ID=

# ========== WALLET & ADRESSEN ==========
MY_ADDRESS=0x671bf669a858c97a1ca7ed3c5c31901ffb671ceea31e8fd706d0b6e2cb8a15c5
PARTNER_ADDRESS=0x0748329ee31e531f5f13fa56b8f42f5173f5518c4dc00e9a090132b1d3c495c5
PARTNER_ADDRESS_FILE=.morgendrot-partner

# ========== ROLLE ==========
ROLE=messenger

# ========== OPTIONALE MODI ==========
ENABLE_PAIRWISE_GROUPS=true
PARTNER_ADDRESSES=0x0748329ee31e531f5f13fa56b8f42f5173f5518c4dc00e9a090132b1d3c495c5,0x2070bf57c91909459427effd0e1e0d348f8fc1967389f8c553fc43656aa29eb8
ENABLE_BROADCAST_PINNWAND=true
BROADCAST_PINNWAND_ADDRESS=0x671bf669a858c97a1ca7ed3c5c31901ffb671ceea31e8fd706d0b6e2cb8a15c5
BROADCAST_AUTHORIZED_SENDERS=0x0748329ee31e531f5f13fa56b8f42f5173f5518c4dc00e9a090132b1d3c495c5
BOSS_ADDRESS=
KOMMANDANT_ADDRESSES=
WORKER_ADDRESSES=

# ========== M2M LOCK ==========
LOCK_ID=

# ========== ZEIT / TTL ==========
DEFAULT_TTL_DAYS=30
DEFAULT_KEY_TTL_DAYS=30
LISTENER_POLL_MS=5000
HANDSHAKE_REFRESH_MS=5000
LOCK_PEER_REFRESH_MS=15000
LOCK_COMMAND_POLL_MS=3000

# ========== FEATURES ==========
VAULT_FILE=
USE_MAILBOX=false
LOG_VERBOSE=false
ENABLE_FILE_LOGGING=true
ENABLE_REPLAY_PROTECTION=true
ENABLE_HARDWARE_OPEN=true
ENABLE_PLAINTEXT_CHANNEL=true
ENABLE_PURGE=true
USE_ENCRYPTED_DISCOVERY=false
ENABLE_LISTENER=true
FETCH_LAST_ON_START=0
ENABLE_FETCH_COMMAND=true
ENABLE_AUTO_EXECUTE=true

# ========== LISTENER & AUTO-BEFEHLE ==========
AUTHORIZED_SENDERS=0x0748329ee31e531f5f13fa56b8f42f5173f5518c4dc00e9a090132b1d3c495c5
MAX_SEND_AMOUNT_IOTA=

# ========== REPLAY-SCHUTZ ==========
REPLAY_STATE_FILE=

# ========== HARDWARE BEI OPEN (Lock) ==========
OPEN_COMMAND=
OPEN_URL=
OPEN_COMMAND_WORDS=open,öffnen,auf
OPEN_COMMAND_LIST_FILE=
OPEN_COMMAND_LIST_KEY=

# ========== STREAMS (letzte Meile) ==========
OPEN_STREAMS_ENABLED=false
STREAMS_ANCHOR_ID=
STREAMS_TOPIC=
STREAMS_LISTEN_ENABLED=false
STREAMS_BRIDGE_URL=

# ========== ZAHLUNGS-TRIGGER (Lock) ==========
PAYMENT_TRIGGER_ENABLED=true
PAYMENT_TRIGGER_MIN_IOTA=
PAYMENT_TRIGGER_POLL_MS=15000
PAYMENT_TRIGGER_STATE_FILE=
PAYMENT_TRIGGER_REQUIRE_MEMO=

# ========== OFFLINE-FÄHIGKEIT (Lock) ==========
OFFLINE_OPEN_ENABLED=false
OFFLINE_CACHE_TTL_MS=86400000
OFFLINE_QUEUE_FILE=

# ========== HEARTBEAT & MONITOR ==========
ENABLE_HEARTBEAT=false
HEARTBEAT_INTERVAL_MS=600000
# Messenger + Monitor in einer Instanz: ENABLE_MONITOR=true (ROLE bleibt messenger)
ENABLE_MONITOR=true
MONITOR_DEVICES=0x0748329ee31e531f5f13fa56b8f42f5173f5518c4dc00e9a090132b1d3c495c5,0x2070bf57c91909459427effd0e1e0d348f8fc1967389f8c553fc43656aa29eb8
MONITOR_OFFLINE_TIMEOUT_MS=1800000
MONITOR_STATE_FILE=
MONITOR_CHECK_INTERVAL_MS=300000
# Relay: Morgendrot sendet Alarm-POST hierhin; Relay leitet an Telegram weiter (npm run telegram-webhook)
MONITOR_ALARM_WEBHOOK_URL=http://127.0.0.1:8787/morgendrot-telegram

# ========== CHAIN-ANCHOR (Messenger) ==========
ENABLE_CHAIN_ANCHOR=false
ANCHOR_INTERVAL_MS=86400000

# ========== LOG-ROTATION ==========
LOG_MAX_FILES=7
LOG_MAX_SIZE=20m

# ========== SIGNER ==========
SIGNER=cli
REMOTE_SIGNER_URL=
REMOTE_SIGNER_TOKEN=
WALLET_DERIVATION_PATH=

# ========== GAS ==========
GAS_BUDGET=10000000

# ========== UI ==========
ENABLE_UI=true
UI_PORT=3341
API_PORT=3342

# ========== TELEGRAM (Relay) ==========
# Nur für das Relay (scripts/telegram-webhook.ts). Echten Token NUR in .env setzen, nie committen!
TG_BOT_TOKEN=<DEIN_BOT_TOKEN_HIER>
TG_CHAT_ID=1156058618
TG_WEBHOOK_PORT=8787
