{
  "name": "morgendrot-messenger-verkauf",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "cross-env UI_VARIANT=messenger MESSENGER_EDITION=sales tsx src/start-with-secrets.ts",
    "start:secrets": "tsx src/start-with-secrets.ts",
    "start:with-streams": "cross-env UI_VARIANT=messenger MESSENGER_EDITION=sales concurrently --names \"app,streams\" -c \"cyan,magenta\" \"npm run start:secrets\" \"npm run streams-mock:persist\"",
    "streams-mock": "tsx scripts/streams-bridge-mock.ts",
    "streams-mock:persist": "cross-env STREAMS_MOCK_PERSIST=1 tsx scripts/streams-bridge-mock.ts",
    "desktop": "electron main.cjs",
    "validate:ui": "node scripts/validate-ui-data.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/run-tests.ts",
    "test:messenger": "tsx scripts/run-messages-chat-realworld.ts",
    "test:messages": "tsx scripts/run-messages-chat-realworld.ts",
    "test:pairing": "tsx scripts/run-pairing-realworld.ts",
    "test:lite-ui-api": "tsx scripts/run-lite-ui-realworld-tests.ts",
    "build:lite-ui": "npx @tailwindcss/cli -i ui/input.css -o ui/styles.css --minify"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.3",
    "@types/winston": "^2.4.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "puppeteer": "^24.39.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "electron": "^33.4.0"
  },
  "dependencies": {
    "@iota/iota-sdk": "^1.11.0",
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "pdfkit": "^0.17.2",
    "readline-sync": "^1.4.10",
    "tsx": "^4.21.0",
    "undici": "^7.24.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "private": true,
  "description": "Morgendrot Verkaufs-Messenger (sales): Schatten/Sweep-Fokus. npm install; Boss-.env; npm start."
}
