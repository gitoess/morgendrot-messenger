import requests
import time
import json
import os
from datetime import datetime
from iota_sdk import Client

# Pfad zur Konfigurationsdatei
MAP_FILE = "factory-io-map.json"

def load_settings():
    """Lädt Node-URL und Mapping aus der JSON-Datei."""
    defaults = {
        "iota_node": "https://api.testnet.iotaledger.net",
        "tag_name": "FACTORY_IO_DATA",
        "interval": 5
    }
    if os.path.exists(MAP_FILE):
        try:
            with open(MAP_FILE, 'r', encoding='utf-8') as f:
                data = json.load(f)
                return data.get("config", defaults), data.get("mapping", {})
        except Exception as e:
            print(f"!!! JSON-Fehler: {e} - Nutze Standards.")
    return defaults, {}

# 1. Einstellungen laden
config, mapping = load_settings()

# 2. IOTA Client mit der URL aus der JSON starten
try:
    client = Client(nodes=[config["iota_node"]])
    print(f"--- Verbunden mit IOTA: {config['iota_node']} ---")
except Exception as e:
    print(f"!!! IOTA Verbindungsfehler: {e}")
    exit()

print(f"Sende-Intervall: {config['interval']} Sekunden. Drücke STRG+C zum Beenden.")

# 3. Hauptschleife
try:
    while True:
        try:
            # Daten von Factory I/O abrufen
            response = requests.get("http://localhost:7410/api/tags", timeout=3)
            
            if response.status_code == 200:
                tags = response.json()
                
                # Sensornamen übersetzen (Mapping)
                sensor_values = {}
                for t in tags:
                    raw_name = t.get('name', 'Unknown')
                    # Nutze Mapping falls vorhanden, sonst Originalname
                    clean_name = mapping.get(raw_name, raw_name)
                    sensor_values[clean_name] = t.get('value', 0)
                
                # Datenpaket für das Tangle vorbereiten
                payload = {
                    "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                    "factory_data": sensor_values
                }
                
                # Paket in Bytes umwandeln und senden
                payload_bytes = json.dumps(payload).encode("utf-8")
                block = client.build_and_post_block(tag=config["tag_name"], data=payload_bytes)
                
                print(f"[{payload['timestamp']}] Daten erfolgreich gesendet! Block ID: {block}")
            else:
                print("Fehler: Factory I/O antwortet nicht korrekt (Status 200 fehlt).")

        except requests.exceptions.ConnectionError:
            print("Warte auf Factory I/O... (Ist 'app.web_server = True' aktiv?)")
        except Exception as e:
            print(f"Fehler im Ablauf: {e}")

        # Warten bis zum nächsten Durchlauf
        time.sleep(config["interval"])

except KeyboardInterrupt:
    print("\nBrücke wurde manuell gestoppt.")
