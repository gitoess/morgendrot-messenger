{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    /* Nur ES2022: vermeidet DOM-CryptoKey vs. node:crypto.webcrypto (KeyUsage/BufferSource). fetch ist über @types/node. */
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@morgendrot/core": ["./packages/morgendrot-core/src/index.ts"],
      "@morgendrot/core/*": ["./packages/morgendrot-core/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
